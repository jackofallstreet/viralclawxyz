{
  "name": "viralclaw",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "build": "turbo run build --filter=@viralclaw-frontend/landing",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "dependencies": {
    "next": "15.1.11",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "prettier": "^3.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": "24.x",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0"
}
